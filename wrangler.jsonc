{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "module-replacements-app",
	"compatibility_date": "2026-04-19",
	"compatibility_flags": ["nodejs_compat"],
	"assets": {
		"directory": "build"
	},
	"workers_dev": true,
	"preview_urls": true,
	"observability": {
		"enabled": true
	}
}
